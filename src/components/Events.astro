---
import Container from "../layouts/Container.astro";
import SubTitle from "./SubTitle.astro";
import eventsData from "../data/EventsData.json";

// Sort events newest-first, defensively handling missing/invalid dates
const events = [...eventsData].sort((a, b) => {
  const ta = Number(new Date(a?.date)) || 0;
  const tb = Number(new Date(b?.date)) || 0;
  return tb - ta; // newest first
});
---

<div class="mb-[5rem] pt-16">
  <Container size="xl">
    <SubTitle
      title="Events I attended"
      text="Here are some of the events I attended recently."
      link="#events"
    />
  </Container>

  {/* Masonry Container */}
  <div
    class="flex flex-col flex-wrap content-start gap-4 overflow-x-auto overflow-y-hidden scrollbar-hide px-4 sm:px-6 md:px-8 lg:px-[10rem] h-[700px]"
  >
    {
      events.map((item) => (
        <div class="w-80 flex-none mb-4 mr-4">
          <div class="space-y-4 h-full">
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-lg overflow-hidden shadow hover:shadow-lg transition relative h-full"
            >
              <div class="relative overflow-hidden bg-dark-200">
                <img
                  src={item.imageUrl}
                  alt={item.name}
                  class="w-full h-auto object-cover transition-transform duration-1000 transform group-hover:scale-95"
                />
                {item.hoverImageUrl && (
                  <img
                    src={item.hoverImageUrl}
                    alt={item.name}
                    class="absolute top-0 left-0 w-full h-full object-cover opacity-0 transition-all duration-1000 transform group-hover:opacity-100 group-hover:scale-105"
                  />
                )}
              </div>
              <div class="absolute inset-0 bg-gradient-to-tr from-black/80 via-black/40 to-transparent flex flex-col justify-end p-4 pointer-events-none">
                <span class="text-sm text-gray-300 mb-2">
                  {item.date
                    ? new Date(item.date).toLocaleDateString("en-US", {
                        month: "short",
                        day: "numeric",
                        year: "numeric",
                      })
                    : ""}
                </span>
                <h3 class="font-bold text-2xl text-white">{item.name}</h3>
                <p class="text-base text-gray-200 line-clamp-3">
                  {item.description}
                </p>
              </div>
            </a>
          </div>
        </div>
      ))
    }

    {/* Spacer to preserve right padding on horizontal scroll */}
    <div class="w-4 sm:w-6 md:w-8 lg:w-[10rem] h-full flex-none"></div>
  </div>
</div>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-hide {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>
